meta {
  name: 2 - Listar Clientes
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/clientes
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Deve retornar array", function() {
    expect(res.body).to.be.an("array");
  });
}

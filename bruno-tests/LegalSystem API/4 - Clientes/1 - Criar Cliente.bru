meta {
  name: 1 - Criar Cliente
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/clientes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

body:json {
  {
    "name": "Carlos Oliveira",
    "cpf": "55566677788"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setVar("clienteId", res.body.id);
  }
}

tests {
  test("Status 200/201 - Cliente criado", function() {
    expect(res.status).to.be.oneOf([200, 201]);
  });
  
  test("Nome deve estar correto", function() {
    expect(res.body.name).to.equal("Carlos Oliveira");
  });
}

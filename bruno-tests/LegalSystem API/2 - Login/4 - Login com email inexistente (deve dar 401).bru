meta {
  name: 4 - Login com email inexistente (deve dar 401)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/login
  body: json
  auth: none
}

body:json {
  {
    "username": "naoexiste@teste.com",
    "password": "123456"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 401 - Usuario nao encontrado", function() {
    expect(res.status).to.equal(401);
  });
}

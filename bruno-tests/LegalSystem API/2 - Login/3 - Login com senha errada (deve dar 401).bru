meta {
  name: 3 - Login com senha errada (deve dar 401)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/login
  body: json
  auth: none
}

body:json {
  {
    "username": "joao@teste.com",
    "password": "senhaErrada123"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 401 - Credenciais invalidas", function() {
    expect(res.status).to.equal(401);
  });
  
  test("Deve retornar mensagem de erro", function() {
    expect(res.body.error).to.include("inv");
  });
}

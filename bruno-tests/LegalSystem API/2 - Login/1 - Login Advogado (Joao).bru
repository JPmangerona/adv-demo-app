meta {
  name: 1 - Login Advogado (Joao)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/login
  body: json
  auth: none
}

body:json {
  {
    "username": "joao@teste.com",
    "password": "123456"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("tokenAdvogado", res.body.token);
    bru.setVar("advogadoId", res.body.user.id);
  }
}

tests {
  test("Status 200 - Login OK", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Deve retornar token JWT", function() {
    expect(res.body.token).to.be.a("string");
    expect(res.body.token.length).to.be.greaterThan(20);
  });
  
  test("Deve retornar dados do usuario", function() {
    expect(res.body.user.name).to.equal("Joao Silva");
    expect(res.body.user.email).to.equal("joao@teste.com");
  });
  
  test("Role deve ser ADVOGADO", function() {
    expect(res.body.user.role).to.equal("ADVOGADO");
  });
}

meta {
  name: 2 - Login Admin
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/login
  body: json
  auth: none
}

body:json {
  {
    "username": "admin@teste.com",
    "password": "123456"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("tokenAdmin", res.body.token);
  }
}

tests {
  test("Status 200 - Login OK", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Deve retornar token JWT", function() {
    expect(res.body.token).to.be.a("string");
  });
  
  test("Role deve ser ADMIN", function() {
    expect(res.body.user.role).to.equal("ADMIN");
  });
}

docs {
  # Pre-requisito
  O usuario admin@teste.com precisa existir no banco com role ADMIN.
  Veja a pasta "1 - Cadastro Publico" request 3 para instrucoes.
}

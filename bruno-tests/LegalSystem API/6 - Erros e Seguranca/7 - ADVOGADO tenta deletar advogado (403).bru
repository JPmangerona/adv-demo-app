meta {
  name: 7 - ADVOGADO tenta deletar advogado (403)
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/advogados/{{advogadoId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 403 - ADVOGADO nao pode deletar advogados", function() {
    expect(res.status).to.equal(403);
  });
}

docs {
  # Teste de role
  Um ADVOGADO tenta deletar outro advogado.
  Somente ADMIN pode fazer isso. Deve retornar 403.
}

meta {
  name: 5 - ADVOGADO tenta listar advogados (403)
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/advogados
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 403 - ADVOGADO nao pode listar advogados", function() {
    expect(res.status).to.equal(403);
  });
}

docs {
  # Teste de role
  Um usuario com role ADVOGADO tenta acessar GET /advogados que e restrito a ADMIN.
  Deve retornar 403 Forbidden.
}

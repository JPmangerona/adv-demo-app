meta {
  name: 10 - Header Authorization com lixo (403)
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/processos
  body: none
  auth: bearer
}

auth:bearer {
  token: isto-nao-e-um-token-valido-123456
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 403 - Token lixo rejeitado", function() {
    expect(res.status).to.equal(403);
  });
}

docs {
  # Token completamente invalido
  Envia uma string qualquer como token para garantir que o backend
  rejeita qualquer coisa que nao seja um JWT valido.
}

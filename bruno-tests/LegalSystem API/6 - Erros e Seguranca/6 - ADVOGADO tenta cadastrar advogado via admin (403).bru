meta {
  name: 6 - ADVOGADO tenta cadastrar advogado via admin (403)
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/advogados/admin
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

body:json {
  {
    "cpf": "99988877766",
    "name": "Hacker Tentativa",
    "username": "hacker@teste.com",
    "email": "hacker@teste.com",
    "password": "123456",
    "oab": "00000XX",
    "role": "ADMIN"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 403 - ADVOGADO nao pode criar via endpoint admin", function() {
    expect(res.status).to.equal(403);
  });
}

docs {
  # Teste critico de seguranca
  Um ADVOGADO tenta usar o endpoint exclusivo de ADMIN para criar outro advogado.
  Deve retornar 403 Forbidden.
}

meta {
  name: 9 - POST processo SEM token (403)
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/processos
  body: json
  auth: none
}

body:json {
  {
    "numeroProcesso": "9999999-99.9999.9.99.9999",
    "titulo": "Processo fantasma",
    "status": "Ativo"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 403 - Nao pode criar processo sem autenticacao", function() {
    expect(res.status).to.equal(403);
  });
}

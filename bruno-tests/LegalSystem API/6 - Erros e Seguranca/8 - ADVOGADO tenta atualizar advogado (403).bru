meta {
  name: 8 - ADVOGADO tenta atualizar advogado (403)
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/advogados/{{advogadoId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

body:json {
  {
    "name": "Tentativa de Alteracao",
    "email": "joao@teste.com",
    "oab": "00000XX",
    "username": "joao@teste.com"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 403 - ADVOGADO nao pode atualizar advogados", function() {
    expect(res.status).to.equal(403);
  });
}

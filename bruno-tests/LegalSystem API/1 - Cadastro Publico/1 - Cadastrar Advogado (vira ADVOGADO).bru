meta {
  name: 1 - Cadastrar Advogado (vira ADVOGADO)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/advogados
  body: json
  auth: none
}

body:json {
  {
    "cpf": "98765432100",
    "name": "Joao Silva",
    "username": "joao@teste.com",
    "email": "joao@teste.com",
    "password": "123456",
    "oab": "67890RJ"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setVar("advogadoId", res.body.id);
  }
}

tests {
  test("Status 201 - Criado com sucesso", function() {
    expect(res.status).to.be.oneOf([200, 201]);
  });
  
  test("Role deve ser ADVOGADO (nao ADMIN)", function() {
    expect(res.body.role).to.equal("ADVOGADO");
  });
  
  test("Nome deve ser Joao Silva", function() {
    expect(res.body.name).to.equal("Joao Silva");
  });
}

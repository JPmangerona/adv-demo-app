meta {
  name: 3 - Cadastrar Admin para testes (inserir no banco antes)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/advogados
  body: json
  auth: none
}

body:json {
  {
    "cpf": "12345678900",
    "name": "Admin Teste",
    "username": "admin@teste.com",
    "email": "admin@teste.com",
    "password": "123456",
    "oab": "12345SP"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 201 - Criado com sucesso", function() {
    expect(res.status).to.be.oneOf([200, 201]);
  });
}

docs {
  # ATENCAO
  
  Este request cria um advogado normal (ADVOGADO).
  Para ter um ADMIN para os testes, voce precisa:
  
  1. Executar este request para criar o usuario
  2. Alterar a role no banco de dados:
  
  ```sql
  UPDATE advogado SET role = 'ADMIN' WHERE email = 'admin@teste.com';
  ```
  
  Ou usar o INSERT direto do REFATORACAO-JWT.md.
}

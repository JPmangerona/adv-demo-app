meta {
  name: 2 - Cadastrar Advogado enviando ADMIN (deve ignorar e criar ADVOGADO)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/advogados
  body: json
  auth: none
}

body:json {
  {
    "cpf": "11111111111",
    "name": "Tentativa Admin",
    "username": "tentativa@teste.com",
    "email": "tentativa@teste.com",
    "password": "123456",
    "oab": "99999SP",
    "role": "ADMIN"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 201 - Criado com sucesso", function() {
    expect(res.status).to.be.oneOf([200, 201]);
  });
  
  test("Role deve ser ADVOGADO mesmo enviando ADMIN", function() {
    expect(res.body.role).to.equal("ADVOGADO");
  });
}

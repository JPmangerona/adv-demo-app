meta {
  name: 3 - Cadastrar Advogado como ADVOGADO via admin
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/advogados/admin
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdmin}}
}

body:json {
  {
    "cpf": "33344455566",
    "name": "Pedro Santos",
    "username": "pedro@teste.com",
    "email": "pedro@teste.com",
    "password": "123456",
    "oab": "22222RJ",
    "role": "ADVOGADO"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 201 - Criado", function() {
    expect(res.status).to.be.oneOf([200, 201]);
  });
  
  test("Role deve ser ADVOGADO", function() {
    expect(res.body.role).to.equal("ADVOGADO");
  });
}

meta {
  name: 5 - Excluir Advogado criado (como Admin)
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/advogados/{{advogadoCriadoId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdmin}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200 - Excluido pelo admin", function() {
    expect(res.status).to.equal(200);
  });
}

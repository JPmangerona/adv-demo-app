meta {
  name: 2 - Cadastrar Advogado como Admin (pode definir role)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/advogados/admin
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdmin}}
}

body:json {
  {
    "cpf": "22233344455",
    "name": "Maria Souza",
    "username": "maria@teste.com",
    "email": "maria@teste.com",
    "password": "123456",
    "oab": "11111SP",
    "role": "ADMIN"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setVar("advogadoCriadoId", res.body.id);
  }
}

tests {
  test("Status 201 - Criado pelo admin", function() {
    expect(res.status).to.be.oneOf([200, 201]);
  });
  
  test("Role deve ser ADMIN (definida pelo admin)", function() {
    expect(res.body.role).to.equal("ADMIN");
  });
}

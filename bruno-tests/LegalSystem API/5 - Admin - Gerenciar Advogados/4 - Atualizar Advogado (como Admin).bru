meta {
  name: 4 - Atualizar Advogado (como Admin)
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/advogados/{{advogadoId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdmin}}
}

body:json {
  {
    "name": "Joao Silva Atualizado",
    "email": "joao@teste.com",
    "oab": "99999SP",
    "username": "joao@teste.com"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200 - Atualizado pelo admin", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Nome deve estar atualizado", function() {
    expect(res.body.name).to.equal("Joao Silva Atualizado");
  });
}

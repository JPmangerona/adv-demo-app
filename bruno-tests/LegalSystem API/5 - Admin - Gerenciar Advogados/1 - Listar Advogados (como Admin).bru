meta {
  name: 1 - Listar Advogados (como Admin)
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/advogados
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdmin}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Deve retornar array de advogados", function() {
    expect(res.body).to.be.an("array");
    expect(res.body.length).to.be.greaterThan(0);
  });
}

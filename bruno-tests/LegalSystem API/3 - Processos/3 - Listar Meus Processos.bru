meta {
  name: 3 - Listar Meus Processos
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/processos
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Deve retornar array de processos", function() {
    expect(res.body).to.be.an("array");
  });
  
  test("Deve ter pelo menos 2 processos (os que acabamos de criar)", function() {
    expect(res.body.length).to.be.greaterThanOrEqual(2);
  });
  
  test("Todos os processos devem ser do advogado logado", function() {
    res.body.forEach(processo => {
      expect(processo.advogado.email).to.equal("joao@teste.com");
    });
  });
}

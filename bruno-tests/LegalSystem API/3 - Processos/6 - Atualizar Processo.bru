meta {
  name: 6 - Atualizar Processo
  type: http
  seq: 6
}

put {
  url: {{baseUrl}}/processos/{{processoId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

body:json {
  {
    "numeroProcesso": "0001234-56.2024.8.16.0001",
    "titulo": "Indenizatoria - Joao vs Telefonica (Atualizado)",
    "descricao": "Acao atualizada com novos fatos",
    "tribunal": "TJPR",
    "vara": "3a Vara Civel",
    "status": "Em Andamento"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200 - Atualizado", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Titulo deve estar atualizado", function() {
    expect(res.body.titulo).to.include("Atualizado");
  });
  
  test("Status deve ser Em Andamento", function() {
    expect(res.body.status).to.equal("Em Andamento");
  });
}

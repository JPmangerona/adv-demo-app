meta {
  name: 1 - Criar Processo (como Advogado)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/processos
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

body:json {
  {
    "numeroProcesso": "0001234-56.2024.8.16.0001",
    "titulo": "Indenizatoria - Joao vs Telefonica",
    "descricao": "Acao de indenizacao por danos morais e materiais",
    "tribunal": "TJPR",
    "vara": "2a Vara Civel",
    "status": "Ativo"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setVar("processoId", res.body.id);
  }
}

tests {
  test("Status 201 - Processo criado", function() {
    expect(res.status).to.be.oneOf([200, 201]);
  });
  
  test("Processo deve ter advogado vinculado", function() {
    expect(res.body.advogado).to.not.be.null;
    expect(res.body.advogado.email).to.equal("joao@teste.com");
  });
  
  test("Dados do processo devem estar corretos", function() {
    expect(res.body.titulo).to.equal("Indenizatoria - Joao vs Telefonica");
    expect(res.body.status).to.equal("Ativo");
  });
}

meta {
  name: 7 - Excluir Processo
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/processos/{{processoId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200 - Excluido com sucesso", function() {
    expect(res.status).to.equal(200);
  });
}

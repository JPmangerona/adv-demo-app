meta {
  name: 2 - Criar Segundo Processo
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/processos
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

body:json {
  {
    "numeroProcesso": "0009876-54.2024.8.16.0002",
    "titulo": "Trabalhista - Maria vs Empresa XYZ",
    "descricao": "Reclamacao trabalhista por horas extras nao pagas",
    "tribunal": "TRT9",
    "vara": "1a Vara do Trabalho",
    "status": "Em Recurso"
  }
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 201 - Segundo processo criado", function() {
    expect(res.status).to.be.oneOf([200, 201]);
  });
}

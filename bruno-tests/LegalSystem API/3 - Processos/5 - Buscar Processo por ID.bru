meta {
  name: 5 - Buscar Processo por ID
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/processos/{{processoId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdvogado}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Deve retornar o processo correto", function() {
    expect(res.body.id).to.equal(bru.getVar("processoId"));
  });
}

meta {
  name: 4 - Listar Processos como Admin (deve retornar vazio ou so os dele)
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/processos
  body: none
  auth: bearer
}

auth:bearer {
  token: {{tokenAdmin}}
}

vars:pre-request {
  baseUrl: http://localhost:6000
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Deve retornar array (possivelmente vazio)", function() {
    expect(res.body).to.be.an("array");
  });
  
  test("Nao deve conter processos do Joao", function() {
    res.body.forEach(processo => {
      expect(processo.advogado.email).to.not.equal("joao@teste.com");
    });
  });
}

docs {
  # O que testar aqui
  O admin tem seus proprios processos. Ele NAO ve os processos do Joao.
  Se o admin nao criou nenhum processo, a lista vem vazia.
  Isso prova que o filtro por advogado esta funcionando.
}
